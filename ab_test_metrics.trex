<?xml version='1.0' encoding='utf-8' ?>
<manifest manifest-version='0.1' xmlns='http://www.tableau.com/xml/extension_manifest'>
  <dashboard-extension id='com.promova.ab-test-quick-metrics' extension-version='1.0.0'>
    <default-locale>en_US</default-locale>
    <name resource-id='name'>AB Test Quick Metrics</name>
    <description resource-id='description'>Quick view of key metrics and statistical significance for the selected A/B experiment</description>
    <author name='Promova' email='analytics@promova.com' organization='Promova' website='https://promova.com' />
    <min-api-version>1.4</min-api-version>
    <source-location>
      <!-- GitHub Pages (production) -->
      <url>https://yevmianovskyi.github.io/test_extension/index.html</url>
      <!-- Local dev: python3 -m http.server 8765 → http://localhost:8765/index.html -->
    </source-location>
    <icon></icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </dashboard-extension>
  <resources>
    <resource id='name'>
      <text locale='en_US'>AB Test Quick Metrics</text>
    </resource>
    <resource id='description'>
      <text locale='en_US'>Quick view of key metrics and statistical significance for the selected A/B experiment. Responds to the Timeline Tracking action filter.</text>
    </resource>
  </resources>
</manifest>
